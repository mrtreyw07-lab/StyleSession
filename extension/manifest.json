{
  "manifest_version": 3,
  "name": "StyleSession",
  "description": "Visual CSS inspector with real undo/redo, session persistence, and clean CSS export. Point-and-click style editing on any website.",
  "version": "1.0.0",
  "author": "Charles Wright",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle StyleSession"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ]
}
